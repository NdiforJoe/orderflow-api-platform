<!--
    partner-product-policy.xml
    Applies to Partner product — B2B machine-to-machine consumers
    Auth: client credentials flow, no user present
    Lower rate limit — external consumers, stricter controls
    IP allowlist: partners must register their egress IPs
-->
<policies>
    <inbound>
        <base />
        <!-- Partners get lower rate limit: 60/min -->
        <rate-limit-by-key calls="60"
                           renewal-period="60"
                           counter-key="@(context.Subscription.Id)" />
        <!--
            QUOTA — monthly cap per partner subscription
            Prevents runaway API consumption without commercial agreement
        -->
        <quota-by-key calls="100000"
                      renewal-period="2592000"
                      counter-key="@(context.Subscription.Id)" />
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>