<!--
    global-policy.xml
    Applies to ALL APIs across ALL products
    WAF Security: correlation ID, security headers, payload size limit, IP logging
    WAF Operational Excellence: structured logging, request tracking
-->
<policies>
    <inbound>
        <!--
            CORRELATION ID
            If APIM receives X-Correlation-Id from caller, use it
            Otherwise generate a new one — ensures every request is traceable
            end-to-end: AFD → APIM → App Service → SQL
        -->
        <set-variable name="correlationId"
            value="@(context.Request.Headers.GetValueOrDefault("X-Correlation-Id", Guid.NewGuid().ToString()))" />
        <set-header name="X-Correlation-Id" exists-action="override">
            <value>@((string)context.Variables["correlationId"])</value>
        </set-header>

        <!--
            SECURITY HEADERS
            Set on all inbound requests forwarded to backend
            Backend adds its own headers too (defence in depth)
        -->
        <set-header name="X-Content-Type-Options" exists-action="override">
            <value>nosniff</value>
        </set-header>
        <set-header name="X-Frame-Options" exists-action="override">
            <value>DENY</value>
        </set-header>

        <!--
            PAYLOAD SIZE LIMIT
            Reject requests larger than 1MB at the gateway
            Prevents large payload attacks before they reach the backend
        -->
        <choose>
            <when condition="@(context.Request.Headers.GetValueOrDefault("Content-Length", "0").Any(v => int.Parse(v) > 1048576))">
                <return-response>
                    <set-status code="413" reason="Payload Too Large" />
                    <set-body>{"error": "Request payload exceeds 1MB limit"}</set-body>
                </return-response>
            </when>
        </choose>

        <!--
            REMOVE INTERNAL HEADERS
            Strip any headers the caller tries to inject
            Prevents callers from spoofing X-Consumer-Id or X-Tenant-Id
        -->
        <set-header name="X-Consumer-Id" exists-action="delete" />
        <set-header name="X-Tenant-Id" exists-action="delete" />
        <set-header name="X-Consumer-Scope" exists-action="delete" />
    </inbound>
    <backend>
        <forward-request timeout="30" follow-redirects="false" />
    </backend>
    <outbound>
        <!--
            PROPAGATE CORRELATION ID TO CALLER
            Caller can use this to reference their request in support tickets
        -->
        <set-header name="X-Correlation-Id" exists-action="override">
            <value>@((string)context.Variables["correlationId"])</value>
        </set-header>

        <!--
            REMOVE SERVER HEADERS
            Don't expose internal infrastructure details to callers
        -->
        <set-header name="X-Powered-By" exists-action="delete" />
        <set-header name="X-AspNet-Version" exists-action="delete" />
        <set-header name="Server" exists-action="delete" />
    </outbound>
    <on-error>
        <set-header name="X-Correlation-Id" exists-action="override">
            <value>@((string)context.Variables["correlationId"])</value>
        </set-header>
    </on-error>
</policies>